{
  "name": "@vex/vex",
  "version": "1.0.0",
  "private": true,
  "description": "Vex desktop app workspace and local agent runtime",
  "type": "module",
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.cjs",
    "build": "pnpm run clean && pnpm exec tsc && pnpm exec tsc-alias --outDir dist",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest/integration.config.ts",
    "test:eval": "vitest run --config vitest/eval.config.ts",
    "test:eval:e2e": "VEX_E2E_MEMORY_EVAL=1 vitest run --config vitest/eval.config.ts src/__tests__/integration/eval/e2e-memory-correctness.int.test.ts",
    "test:eval:dense": "VEX_REAL_DENSE_EVAL=1 vitest run --config vitest/dense-eval.config.ts",
    "test:eval:latency": "VEX_REAL_LATENCY_EVAL=1 vitest run --config vitest/latency-eval.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "knowledge-export": "tsx src/vex-agent/scripts/knowledge-export.ts",
    "knowledge-import": "tsx src/vex-agent/scripts/knowledge-import.ts",
    "knowledge-reembed": "tsx src/vex-agent/scripts/knowledge-reembed.ts",
    "tool-reembed": "tsx src/vex-agent/scripts/tool-reembed.ts",
    "tool-embeddings:health": "tsx src/vex-agent/scripts/tool-embeddings-health.ts",
    "benchmark-cross-lingual": "tsx src/vex-agent/scripts/cross-lingual-benchmark.ts",
    "vex:dev": "pnpm --dir vex-app install && pnpm --dir vex-app dev",
    "vex:make": "pnpm --dir vex-app make",
    "vex:lint": "pnpm --dir vex-app lint",
    "vex:test": "pnpm --dir vex-app test",
    "vex:test:e2e": "pnpm --dir vex-app test:e2e"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.12.79",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tavily/core": "^0.7.2",
    "bs58": "^6.0.0",
    "ethers": "^6.13.1",
    "pg": "^8.20.0",
    "rettiwt-api": "7.0.3",
    "socket.io-client": "^4.8.3",
    "viem": "2.45.1",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.1"
  },
  "keywords": [
    "defi",
    "blockchain",
    "desktop",
    "agent"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vex-Foundation/Vex.git"
  },
  "homepage": "https://github.com/Vex-Foundation/Vex",
  "bugs": {
    "url": "https://github.com/Vex-Foundation/Vex/issues"
  },
  "packageManager": "pnpm@10.32.1"
}
