{
  "name": "@echoclaw/echo",
  "version": "1.0.11",
  "private": true,
  "description": "EchoClaw echo-agent core",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/**",
    "src/echo-agent/db/migrations/**"
  ],
  "scripts": {
    "clean": "node --input-type=commonjs -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc && tsc-alias",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "knowledge-export": "tsx src/echo-agent/scripts/knowledge-export.ts",
    "knowledge-import": "tsx src/echo-agent/scripts/knowledge-import.ts",
    "knowledge-reembed": "tsx src/echo-agent/scripts/knowledge-reembed.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.1",
    "@0glabs/0g-serving-broker": "^0.7.1",
    "@openrouter/sdk": "^0.9.11",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tavily/core": "^0.7.2",
    "bs58": "^6.0.0",
    "ethers": "^6.13.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "socket.io-client": "^4.8.3",
    "viem": "2.45.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.19.15",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "keywords": [
    "0g",
    "defi",
    "blockchain",
    "mcp",
    "agent"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/EchoClaw-Labs/EchoClaw.git"
  },
  "homepage": "https://github.com/EchoClaw-Labs/EchoClaw",
  "bugs": {
    "url": "https://github.com/EchoClaw-Labs/EchoClaw/issues"
  },
  "packageManager": "pnpm@10.32.1"
}
