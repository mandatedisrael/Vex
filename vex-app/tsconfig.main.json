{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/main",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@vex-lib/*": ["../src/lib/*"],
      "@vex-agent/*": ["../src/vex-agent/*"],
      "@tools/*": ["../src/tools/*"],
      "@utils/*": ["../src/utils/*"],
      "@config/*": ["../src/config/*"]
    }
  },
  "include": ["src/main", "src/shared", "../src/lib"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
