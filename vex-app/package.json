{
  "name": "@vex/app",
  "version": "0.1.4",
  "description": "Vex Electron desktop app — local self-custodial wallet + autonomous on-chain agent GUI",
  "homepage": "https://www.projectvex.ai/",
  "author": "Project VEX",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vex-Foundation/Vex.git"
  },
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "prebuild": "node scripts/copy-migrations.mjs",
    "build": "pnpm run lint && pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "postbuild": "node scripts/check-build-artifacts.mjs",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main:watch": "vite build --config vite.main.config.ts --watch",
    "dev:preload:watch": "vite build --config vite.preload.config.ts --watch",
    "dev:electron": "wait-on --log --timeout 60000 --delay 1500 http-get://127.0.0.1:5173/ && electron dist/main/index.js",
    "dev": "pnpm run build:main && pnpm run build:preload && concurrently --kill-others --names \"renderer,main,preload,electron\" \"pnpm:dev:renderer\" \"pnpm:dev:main:watch\" \"pnpm:dev:preload:watch\" \"pnpm:dev:electron\"",
    "package": "pnpm run build && electron-builder --dir --publish never",
    "make": "pnpm run build && electron-builder --publish never",
    "lint": "pnpm run lint:tsc && pnpm run lint:tsc:ratchet && pnpm run check:boundaries",
    "lint:tsc": "tsc --noEmit -p tsconfig.shared.json && tsc --noEmit -p tsconfig.e2e.json",
    "lint:tsc:ratchet": "node scripts/check-type-baseline.mjs",
    "lint:tsc:ratchet:update": "node scripts/check-type-baseline.mjs --update",
    "lint:tsc:all": "tsc --noEmit -p tsconfig.shared.json && tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.e2e.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit:deps": "pnpm audit --prod && pnpm audit",
    "doctor": "node scripts/doctor.mjs",
    "predev": "node scripts/doctor.mjs && node scripts/copy-migrations.mjs",
    "check:build": "node scripts/check-build-artifacts.mjs",
    "check:boundaries": "node scripts/check-process-boundaries.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "~5.2.2",
    "@hugeicons/core-free-icons": "~4.1.1",
    "@hugeicons/react": "~1.1.6",
    "@sentry/electron": "~7.13.0",
    "@solana/web3.js": "~1.98.4",
    "@tanstack/react-query": "~5.100.9",
    "@thesvg/react": "~3.2.2",
    "@zxcvbn-ts/core": "~4.1.2",
    "@zxcvbn-ts/language-common": "~4.1.2",
    "@zxcvbn-ts/language-en": "~4.1.1",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "electron-log": "~5.4.3",
    "electron-updater": "~6.8.3",
    "marked": "~18.0.3",
    "lightweight-charts": "5.2.0",
    "motion": "~12.38.0",
    "pg": "~8.20.0",
    "react": "~19.2.6",
    "react-dom": "~19.2.6",
    "react-hook-form": "~7.75.0",
    "tailwind-merge": "~3.5.0",
    "viem": "2.54.3",
    "zod": "~4.4.3",
    "zustand": "~5.0.13"
  },
  "devDependencies": {
    "@electron/fuses": "~2.1.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "~4.2.4",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.2",
    "@types/node": "~22.19.17",
    "@types/pg": "~8.20.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.1",
    "concurrently": "~9.2.1",
    "electron": "42.0.0",
    "electron-builder": "~26.8.1",
    "jsdom": "~29.1.1",
    "playwright": "1.59.1",
    "sharp": "~0.34.5",
    "tailwindcss": "~4.2.4",
    "typescript": "6.0.3",
    "vite": "~8.0.11",
    "vitest": "~4.1.5",
    "wait-on": "~9.0.5"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp"
    ]
  }
}
