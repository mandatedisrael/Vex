# Vex Docker Stack
VEX_POSTGRES_PASSWORD=vex
AGENT_AUTH_TOKEN=

# Database — REQUIRED by maintenance commands (knowledge-export/import/reembed).
# The runtime path (MCP server, internal tools) has a dev fallback to
# vex_test if this is unset, but maintenance commands fail-fast to
# prevent silently operating on the wrong DB during a backup or restore.
# Source this file before running any `make knowledge-*` target:
#   set -a; . docker/vex-agent/.env; set +a
VEX_DB_URL=postgresql://vex:vex@localhost:5777/vex

# Web search — log in at https://app.tavily.com/home, open API Keys, and copy
# the key here (1,000 free credits/month, no card required).
TAVILY_API_KEY=

# Twitter/X account research — optional. Rettiwt API_KEY is a base64 encoding
# of account cookies, not an official X developer key. Use a secondary account.
RETTIWT_API_KEY=

# Solana / Jupiter — REQUIRED by Vex MCP runtime and onboarding.
# Log in at https://developers.jup.ag/portal/api-keys, create a new API key,
# and store it in CONFIG_DIR/.env. Jupiter offers a free tier with rate limits.
JUPITER_API_KEY=

# Embeddings — Docker Model Runner with ai/embeddinggemma:300M-Q8_0 (pinned, no HF_TOKEN required).
# Requires: Docker Engine >=4.40, Compose >=2.38.1, Model Runner active.
# Pulled automatically by `docker model pull ai/embeddinggemma:300M-Q8_0` or first compose up.
# Model is distributed under the Gemma Terms of Use — see https://ai.google.dev/gemma/terms
#
# EMBEDDING_DIM is config-driven, NOT schema-locked. Any positive integer in
# [1, 8192] is accepted as long as the configured EMBEDDING_MODEL actually
# returns vectors of that length. To switch model, see README "Switching
# embedding model" — same-dim swaps go through `make knowledge-reembed`,
# different-dim swaps go through export → wipe → import.
EMBEDDING_BASE_URL=http://localhost:12434/engines/llama.cpp/v1
EMBEDDING_MODEL=ai/embeddinggemma:300M-Q8_0
EMBEDDING_DIM=768
EMBEDDING_PROVIDER=local

# Optional overrides:
# VEX_AGENT_IMAGE=ghcr.io/vex-foundation/vex/vex-agent:latest
# AGENT_PORT=4201
# AGENT_BIND_HOST=0.0.0.0    (set in docker-compose.yml; override only if needed)
# LOG_FORMAT=json             (auto-detected from TTY; force json or pretty)
#
# Manual docker compose users should set VEX_CONFIG_DIR explicitly:
# Linux:   VEX_CONFIG_DIR=~/.config/vex
# macOS:   VEX_CONFIG_DIR=~/Library/Application\ Support/vex
# Windows: VEX_CONFIG_DIR=%APPDATA%\vex
